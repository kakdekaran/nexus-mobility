# Nexus Mobility - Production Environment Settings
# Set these in your Render Dashboard (Settings > Environment)

# A long random string for securing sessions. 
# Render will generate this automatically if you use the render.yaml blueprint.
JWT_SECRET=your_super_secret_random_hex_string

# Optional: Set this if you want to use an external database in the future
# DATABASE_URL=

# Port is managed by Render, do not set it here.
